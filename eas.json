{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_LARAVEL_API": "https://staging.edukasof.com/api/v1",
        "EXPO_PUBLIC_NEST_API": "https://staging.edukasof.com/api/v1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_LARAVEL_API": "https://core.edukasof.com/api/v1",
        "EXPO_PUBLIC_NEST_API": "https://core.edukasof.com/api/v1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
